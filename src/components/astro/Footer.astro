---
/**
 * Footer.astro — Full site footer
 * Copyright, built-with Astro attribution, language toggle (phase 08).
 */
import { t, mirrorUrl, type Lang } from '../../lib/i18n-helpers';

interface Props {
  lang?: Lang;
  /** Current page path for mirror URL computation */
  currentPath?: string;
}
const { lang = 'en', currentPath = '/' } = Astro.props;

const year = new Date().getFullYear();
const enUrl  = mirrorUrl(currentPath, 'en');
const viUrl  = mirrorUrl(currentPath, 'vi');
---

<footer class="footer" role="contentinfo">
  <div class="footer-inner">
    <p class="footer-copy">
      &copy; {year} Hoàng Đức Long. {t('footer_rights', lang)}
    </p>

    <p class="footer-built">
      {t('footer_built_with', lang)}
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-link"
        aria-label="Astro framework"
      >Astro</a>
      {t('footer_deployed_on', lang)}
      <a
        href="https://pages.github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-link"
        aria-label="GitHub Pages"
      >GitHub Pages</a>.
    </p>

    <!-- Language toggle — active state driven by lang prop -->
    <div class="lang-toggle" aria-label="Language selector">
      <a
        href={enUrl}
        class:list={['lang-btn', { 'lang-btn--active': lang === 'en' }]}
        aria-current={lang === 'en' ? 'page' : undefined}
      >EN</a>
      <span class="lang-sep" aria-hidden="true">/</span>
      <a
        href={viUrl}
        class:list={['lang-btn', { 'lang-btn--active': lang === 'vi' }]}
        aria-current={lang === 'vi' ? 'page' : undefined}
      >VI</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 2.5rem 1.5rem;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    max-width: 72rem;
    margin-inline: auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 2rem;
  }

  .footer-copy,
  .footer-built {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    margin: 0;
  }

  .footer-link {
    color: var(--text-secondary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }

  .footer-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* Language toggle */
  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
  }

  .lang-btn {
    color: var(--text-tertiary);
    text-decoration: none;
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
    transition: color 0.2s, background 0.2s;
  }

  .lang-btn:hover {
    color: var(--text-primary);
    background: var(--surface-raised);
  }

  .lang-btn--active {
    color: var(--accent);
    font-weight: 600;
  }

  .lang-sep {
    color: var(--border);
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
