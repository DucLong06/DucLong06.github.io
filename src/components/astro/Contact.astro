---
/**
 * Contact.astro — Static contact section
 * Email CTA + social grid + CV download + open-to-work badge
 * NO form, NO Formspree, NO phone number
 */
import SectionTitle from './SectionTitle.astro';
import { t, type Lang } from '../../lib/i18n-helpers';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
---

<section id="contact" class="contact-section">
  <div class="contact-inner">
    <SectionTitle eyebrow={t('contact_eyebrow', lang)} title={t('contact_title', lang)} />

    <!-- Open to work badge -->
    <div class="open-badge">
      <span class="pulse-dot"></span>
      <span>{t('contact_open_badge', lang)}</span>
    </div>

    <!-- Email CTA -->
    <div class="email-block">
      <p class="email-label">{t('contact_email_label', lang)}</p>
      <a
        href="mailto:hoangduclongg@gmail.com"
        class="email-link"
        aria-label="Send email to Hoàng Đức Long"
      >
        hoangduclongg@gmail.com
      </a>
    </div>

    <!-- Social + CV row -->
    <div class="cta-row">
      <!-- Social links -->
      <div class="social-grid">
        <a
          href="https://github.com/DucLong06"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="GitHub profile"
        >
          <!-- GitHub icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/>
          </svg>
          <span>GitHub</span>
        </a>

        <a
          href="https://linkedin.com/in/hoangduclong"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="LinkedIn profile"
        >
          <!-- LinkedIn icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span>LinkedIn</span>
        </a>
      </div>

      <!-- Download CV -->
      <a
        href="/cv.pdf"
        target="_blank"
        rel="noopener noreferrer"
        download
        class="cv-button"
        aria-label="Download CV as PDF"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        {t('contact_download_cv', lang)}
      </a>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 6rem 1.5rem 8rem;
    max-width: 72rem;
    margin-inline: auto;
  }

  .contact-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Open to work badge */
  .open-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 1.125rem;
    border-radius: 9999px;
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.25);
    color: #4ade80;
    font-size: 0.875rem;
    font-weight: 500;
    width: fit-content;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  /* Email block */
  .email-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .email-label {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .email-link {
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    width: fit-content;
  }

  .email-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* CTA row */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-top: 0.5rem;
  }

  /* Social grid */
  .social-grid {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.125rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    font-size: 0.9375rem;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .social-link:hover {
    background: var(--surface-raised);
    color: var(--text-primary);
    border-color: var(--accent);
  }

  /* CV download button */
  .cv-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.375rem;
    border-radius: 0.5rem;
    background: var(--accent);
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.15s;
  }

  .cv-button:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse-dot {
      animation: none;
    }
    .cv-button,
    .email-link {
      transition: none;
    }
  }

  @media (max-width: 640px) {
    .contact-section {
      padding: 4rem 1rem 6rem;
    }
    .email-link {
      font-size: 1.125rem;
    }
    .cta-row {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
