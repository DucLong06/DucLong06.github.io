---
/**
 * SkillBar.astro — Single skill row with name and filled bar (level/5).
 * Bar fill uses aurora gradient. Label truncated with ellipsis if overlong.
 */
interface Props {
  name: string;
  level: number; // 1–5
  years?: number;
}
const { name, level, years } = Astro.props;
const fillPct = Math.round((level / 5) * 100);
---

<div class="skill-bar">
  <div class="skill-bar__label">
    <span class="skill-bar__name" title={name}>{name}</span>
    {years && <span class="skill-bar__years">{years}y</span>}
  </div>
  <div
    class="skill-bar__track"
    role="meter"
    aria-valuenow={level}
    aria-valuemin={0}
    aria-valuemax={5}
    aria-label={`${name}: level ${level} of 5`}
  >
    <div class="skill-bar__fill" style={`width: ${fillPct}%`}></div>
  </div>
</div>

<style>
  .skill-bar {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .skill-bar__label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .skill-bar__name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 80%;
  }

  .skill-bar__years {
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .skill-bar__track {
    height: 4px;
    background: var(--border);
    border-radius: 999px;
    overflow: hidden;
  }

  .skill-bar__fill {
    height: 100%;
    background: var(--aurora-gradient);
    border-radius: 999px;
    transition: width 0.6s var(--ease-soft, ease);
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-bar__fill {
      transition: none;
    }
  }
</style>
