---
/**
 * SectionTitle.astro — Reusable section headline.
 * Props: eyebrow (small label above), title (main heading), align (left|center)
 */
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, align = 'left' } = Astro.props;
---

<div class:list={['section-title', `section-title--${align}`]}>
  {eyebrow && <span class="section-title__eyebrow">{eyebrow}</span>}
  <h2 class="section-title__heading">{title}</h2>
</div>

<style>
  .section-title {
    margin-bottom: 3rem;
  }

  .section-title--center {
    text-align: center;
  }

  .section-title__eyebrow {
    display: block;
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--aurora-1);
    margin-bottom: 0.5rem;
  }

  .section-title__heading {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0;
  }
</style>
