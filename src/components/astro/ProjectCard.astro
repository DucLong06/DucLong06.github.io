---
/**
 * ProjectCard.astro — Single project card for the bento grid.
 * Shows: gradient cover (placeholder until Phase 09), stars badge, title,
 * summary.en, stack pills (max 6 + "+N more"), repo/demo icons.
 *
 * Link strategy: outer card is a <div> with a stretched <a> overlay (::after).
 * Repo/demo links sit above via position:relative + z-index:1 — avoids
 * invalid nested <a> HTML. Whole card wrapped in MagneticTilt island.
 */
import MagneticTilt from '../react/MagneticTilt';
import { t, type Lang } from '../../lib/i18n-helpers';

interface Props {
  slug: string;
  title: string;
  summary: { en: string; vi: string };
  stack: string[];
  stars?: number;
  repo?: string;
  demo?: string;
  /** Hero card: larger text + taller cover */
  hero?: boolean;
  lang?: Lang;
}

const { slug, title, summary, stack, stars, repo, demo, hero = false, lang = 'en' } = Astro.props;

// Resolve bilingual summary outside JSX to avoid template-parser type confusion
const summaryText: string = (summary as Record<string, string>)[lang] ?? summary.en;

// Known slugs with generated WebP covers (Phase 09)
const KNOWN_COVERS = new Set([
  'face-detection-ml-system',
  'booking-duongcam-art',
  'legal-prompts',
  'alqac-2023',
  'text2sql-vietnamese',
  'ocr-api',
]);

const hasCover = KNOWN_COVERS.has(slug);
const coverSrc = `/covers/${slug}.webp`;
// Fallback gradient for slugs without a cover image
const coverGradient = 'linear-gradient(135deg,#6366f1,#8b5cf6)';

// Stack pills: max 6 visible, "+N more" for overflow
const MAX_PILLS = 6;
const visibleStack = stack.slice(0, MAX_PILLS);
const overflow = stack.length - MAX_PILLS;
---

<MagneticTilt client:visible>
  <div class:list={['project-card', { 'project-card--hero': hero }]}>

    <!-- Stretched link covering entire card — no nested <a> -->
    <a
      href={lang === 'vi' ? `/vi/projects/${slug}/` : `/projects/${slug}/`}
      class="project-card__overlay-link"
      aria-label={`View project: ${title}`}
    ></a>

    <!-- Cover: WebP when available, CSS gradient fallback -->
    <div class="project-card__cover" aria-hidden="true">
      {hasCover
        ? <img
            src={coverSrc}
            alt=""
            width="1200"
            height="750"
            loading="lazy"
            decoding="async"
            class="project-card__cover-img"
          />
        : <div class="project-card__cover-gradient" style={`background:${coverGradient}`}>
            <div class="project-card__cover-noise" />
          </div>
      }
    </div>

    <!-- Body -->
    <div class="project-card__body">
      <!-- Header: title + stars badge -->
      <div class="project-card__header">
        <h3 class:list={['project-card__title', { 'project-card__title--hero': hero }]}>
          {title}
        </h3>
        {stars && (
          <span class="project-card__stars" aria-label={`${stars} GitHub stars`}>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            {stars}
          </span>
        )}
      </div>

      <!-- Summary -->
      <p class="project-card__summary">{summaryText}</p>

      <!-- Stack pills -->
      <ul class="project-card__stack" role="list" aria-label="Tech stack">
        {visibleStack.map((tech) => (
          <li class="project-card__pill" role="listitem">{tech}</li>
        ))}
        {overflow > 0 && (
          <li class="project-card__pill project-card__pill--more" role="listitem">
            +{overflow} more
          </li>
        )}
      </ul>

      <!-- Bottom links — z-index above overlay link -->
      <div class="project-card__links">
        {repo && (
          <a
            href={repo}
            class="project-card__link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View source on GitHub"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            {t('project_source', lang)}
          </a>
        )}
        {demo && (
          <a
            href={demo}
            class="project-card__link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View live demo"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            {t('project_demo', lang)}
          </a>
        )}
      </div>
    </div>
  </div>
</MagneticTilt>

<style>
  .project-card {
    position: relative;        /* anchor for overlay link */
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--r-lg, 1rem);
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .project-card:hover,
  .project-card:focus-within {
    border-color: var(--aurora-1);
    box-shadow: 0 0 0 1px var(--aurora-1), 0 8px 32px rgba(99,102,241,0.15);
  }

  /* Stretched overlay link — covers full card at z-index 0 */
  .project-card__overlay-link {
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
  }

  .project-card__overlay-link:focus-visible {
    outline: 2px solid var(--aurora-1);
    outline-offset: 2px;
  }

  /* Cover area */
  .project-card__cover {
    position: relative;
    height: 8rem;
    flex-shrink: 0;
    overflow: hidden;
  }

  .project-card--hero .project-card__cover {
    height: 10rem;
  }

  /* WebP cover image — fills cover slot */
  .project-card__cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Gradient fallback for slugs without WebP */
  .project-card__cover-gradient {
    position: absolute;
    inset: 0;
  }

  .project-card__cover-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.08'/%3E%3C/svg%3E");
    background-size: cover;
  }

  /* Body */
  .project-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.125rem;
    flex: 1;
  }

  .project-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .project-card__title {
    font-family: var(--font-display, 'Instrument Serif', serif);
    font-size: 1.05rem;
    font-weight: 400;
    line-height: 1.25;
    color: var(--text-primary);
    margin: 0;
  }

  .project-card__title--hero {
    font-size: 1.25rem;
  }

  .project-card__stars {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--aurora-2, #8b5cf6);
    background: rgba(139,92,246,0.1);
    border: 1px solid rgba(139,92,246,0.2);
    border-radius: 9999px;
    padding: 0.125rem 0.5rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .project-card__summary {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-card--hero .project-card__summary {
    -webkit-line-clamp: 4;
  }

  /* Stack pills */
  .project-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    margin: 0 0 auto;
  }

  .project-card__pill {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.675rem;
    font-weight: 500;
    color: var(--text-tertiary);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
  }

  .project-card__pill--more {
    color: var(--aurora-1, #6366f1);
    border-color: rgba(99,102,241,0.3);
    background: rgba(99,102,241,0.08);
  }

  /* Bottom links — must float above overlay link */
  .project-card__links {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 0.75rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
    margin-top: 0.25rem;
  }

  .project-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .project-card__link:hover {
    color: var(--aurora-1, #6366f1);
  }

  .project-card__link:focus-visible {
    color: var(--aurora-1, #6366f1);
    outline: 2px solid var(--aurora-1);
    outline-offset: 2px;
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card {
      transition: none;
    }
  }
</style>
